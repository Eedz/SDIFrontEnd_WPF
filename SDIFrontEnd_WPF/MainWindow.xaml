<Window x:Class="SDIFrontEnd_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SDIFrontEnd_WPF"
        mc:Ignorable="d"
        Title="Survey Development Index" Height="700" Width="1400" WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ViewModelDataTemplates.xaml"/>
                
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
            <ListBox Grid.Column="1" Grid.Row="0"
             ItemsSource="{Binding MenuCategories}"
             SelectedItem="{Binding SelectedMenuCategory, Mode=TwoWay}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="8,4">
                            <Rectangle Width="16" Height="16" Fill="Gray" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <DockPanel Grid.Row="1" Grid.Column="1" Background="AliceBlue">
            <ContentControl Content="{Binding ActiveForm}" Margin="10" Background="White" BorderBrush="Gray" 
                            BorderThickness="1" VerticalAlignment="Stretch" >
                
            </ContentControl>
        </DockPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Background="LightGray">
            <Label Content="{Binding SelectedMenuCategory}" FontSize="16" HorizontalAlignment="Center"/>
            
            <ListBox Grid.Row="1" Grid.Column="0"
                 ItemsSource="{Binding CurrentSublinks}"
                     SelectedItem="{Binding SelectedSublink, Mode=TwoWay}"
                 Margin="8"
                 Background="WhiteSmoke"
                 BorderThickness="0">   
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" Padding="4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Margin="0,10,0,0" Visibility="{Binding IsSurveyCategory, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Open a previously viewed survey or choose another below." TextWrapping="Wrap" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                <ComboBox Width="80"
                  ItemsSource="{Binding AvailableSurveysToAdd}"
                  SelectedItem="{Binding SelectedNewSurvey, Mode=TwoWay}"
                  DisplayMemberPath="SurveyCode"
                          Margin="8"
                   />
                <Button Command="{Binding AddSelectedSurveyCommand}" Margin="5,0,0,0" Width="20" Height="20">
                    <Image Source="/Images/add.png"/>
                </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="2" Grid.ColumnSpan="2" BorderThickness="2" BorderBrush="AliceBlue">
            <StackPanel >
                <TextBlock Text="ITC Project 2025" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
