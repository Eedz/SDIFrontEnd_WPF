<UserControl x:Class="SDIFrontEnd_WPF.SurveyBuilder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             xmlns:converters ="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             xmlns:mvvmLib ="clr-namespace:MvvmLib;assembly=MvvmLib"
             xmlns:views="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:MvvmLib.Behaviors;assembly=MvvmLib"
             mc:Ignorable="d" Height="Auto"
             d:DesignHeight="450" d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlow" />
            <converters:QuestionTypeToBrushConverter x:Key="QuestionTypeToBrushConverter"/>
            <converters:QuestionTypeToFontWeightConverter x:Key="QuestionTypeToFontWeightConverter"/>
            <converters:QuestionStatusToBackgroundConverter x:Key="QuestionStatusToBackgroundConverter"/>

            <Style x:Key="QuestionRowStyle" TargetType="DataGridRow">
                <Setter Property="Foreground" Value="{Binding Item.QuestionType, Converter={StaticResource QuestionTypeToBrushConverter}}"/>
                <Setter Property="FontWeight" Value="{Binding Item.QuestionType, Converter={StaticResource QuestionTypeToFontWeightConverter}}"/>
            </Style>
            <Style x:Key="QuestionRowColor" TargetType="DataGridRow" BasedOn="{StaticResource QuestionRowStyle}">
                <Setter Property="Background" Value="{Binding QuestionStatus, Converter={StaticResource QuestionStatusToBackgroundConverter}}"/>
            </Style>
           
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="560"></ColumnDefinition>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
            <ColumnDefinition Width="0.5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        
        <!-- Button menu -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Save" Command="{Binding SaveChangesCommand}" Margin="5,0,20,0" VerticalAlignment="Center"/>
            <StackPanel  Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Add" Command="{Binding AddSurveyQuestionCommand}" Margin="5,0"/>
                    <Button Content="Add Series" Command="{Binding AddSeriesCommand}" Margin="5,0"/>
                    <Button Content="Delete" Command="{Binding RemoveSurveyQuestionCommand}" Margin="5,0"/>
                    <Button Content="Copy Prev" Command="{Binding CopyPreviousWordingsCommand}" Margin="5,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Command="{Binding AddTranslationCommand}" Margin="5,0,0,0">
                        <Image Source="/Images/add.png" Width="15" Height="10"></Image>
                    </Button>
                    <Button Content="Translations" Command="{Binding ViewTranslationsCommand}" Margin="0,0,5,0"/>
                    <Button Content="Deleted Vars" Command="{Binding ViewDeletedVarsCommand}" Margin="5,0"/>
                    <Button Content="Related Qs" Command="{Binding ViewRelatedQuestionsCommand}" Margin="5,0"/>
                </StackPanel>

            </StackPanel>
            <StackPanel>
                <TextBlock>
                    <Run Text="Added: "/>
                    <Run d:Text="Added: 0" Text="{Binding Added.Count, Mode=OneWay}"/>
                    <LineBreak/>
                    <Run Text="Modified: "/>
                    <Run d:Text="Modified: 0" Text="{Binding Modified.Count, Mode=OneWay}"/>
                    <LineBreak/>
                    <Run Text="Deleted: "/>
                    <Run d:Text="Deleted: 0" Text="{Binding Removed.Count, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- VarName/Qnum -->
        <StackPanel Grid.Row="0" Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center">
                <Run Text="{Binding SelectedQuestion.VarName.VarName}" d:Text="VarName" />
                <Run Text="--- Q#"/>
                <Run Text="{Binding SelectedQuestion.Qnum}" d:Text="Qnum" />
            </TextBlock>
            <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock FontWeight="Bold" FontSize="12" Text="AltQ#: " />
                <TextBox Text="{Binding SelectedQuestion.AltQnum}" d:Text="AltQ#" Width="70" DockPanel.Dock="Top" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>
            <TextBlock  HorizontalAlignment="Center" Text="{Binding SectionCount}" FontSize ="10" d:Text="Current Question's section count"/>
        </StackPanel>
        <!-- Question List -->
        <DockPanel  Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" >
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,0">
                <TextBlock Text="Go To" DockPanel.Dock="Top"/>
                <ComboBox Margin="3,0" ItemsSource="{Binding QuestionList}" SelectedItem="{Binding GoToVar}" DisplayMemberPath="VarName" Width="90"/>
            </StackPanel>
            <DataGrid Height="Auto"
                ItemsSource="{Binding RecordList}"
                SelectedItem="{Binding SelectedQuestionRecord}"
                ScrollViewer.VerticalScrollBarVisibility="Visible" 
                VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                AutoGenerateColumns="False" 
                HeadersVisibility="Column"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                AllowDrop="True"
                IsReadOnly="True"
                Margin="5"
                GridLinesVisibility="None"
                SelectionUnit="FullRow"
                mvvmLib:DataGridHelper.BindableSelectedItems="{Binding SelectedQuestionRecords}"
                mvvmLib:DataGridHelper.ScrollOnSelected="True"
                mvvmLib:DataGridHelper.Command="{Binding ToggleQuestionCommand}"
                RowStyle="{StaticResource QuestionRowColor}">

                <i:Interaction.Behaviors>
                    <behaviors:DataGridReorderBehavior MoveCommand="{Binding ReorderCommand}" />
                </i:Interaction.Behaviors>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Qnum" Binding="{Binding Item.Qnum}" Width="60"/>
                    <DataGridTextColumn Header="VarName" Binding="{Binding Item.VarName.VarName}" Width="Auto"/>
                    <DataGridTextColumn Header="VarLabel" Binding="{Binding Item.VarName.VarLabel}" Width="300"/>
                    <DataGridTextColumn Header="RespName" Binding="{Binding Item.RespOptionsS.RespSetName}" Width="Auto"/>
                </DataGrid.Columns>


            </DataGrid>
        </DockPanel>
        
        <!-- Question View -->
        <DockPanel Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" Margin="5" LastChildFill="True" HorizontalAlignment="Stretch">
            <local:NavigationBar DockPanel.Dock="Bottom" 
                                 FirstItemCommand="{Binding FirstItemCommand}"
                                 PreviousItemCommand="{Binding PreviousItemCommand}"
                                 ItemPosition="{Binding ItemPosition}"
                                 NextItemCommand="{Binding NextItemCommand}"
                                 LastItemCommand="{Binding LastItemCommand}"/>
            
          
            <!-- Labels -->
            <Border Margin="0,0,0,5" DockPanel.Dock="Bottom" Background="LightSkyBlue"
                Effect="{StaticResource SunkenEffect}">
                <Grid Margin="5" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"></ColumnDefinition>
                        <ColumnDefinition Width="275"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition ></RowDefinition>
                        <RowDefinition ></RowDefinition>
                        <RowDefinition ></RowDefinition>
                        <RowDefinition ></RowDefinition>
                        <RowDefinition ></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Text="VarLabel:" FontWeight="Bold" Grid.Column="0" Grid.Row="0" Margin="0,0,0,10" FontSize="12" />
                    <TextBox Grid.Column="1" Grid.Row="0" Width="275" MaxHeight="25" Text="{Binding SelectedQuestion.VarName.VarLabel}" VerticalContentAlignment="Top" Padding="3,0,0,0"/>

                    <TextBlock Text="Topic:" Grid.Column="0" Grid.Row="1" Margin="0,0,0,10" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Grid.Row="1" Width="275" MaxHeight="25" ItemsSource="{Binding TopicLabels}" SelectedItem="{Binding SelectedQuestion.VarName.TopicLabel}" DisplayMemberPath="Label"/>

                    <TextBlock Text="Content:" Grid.Column="0" Grid.Row="2" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                    <ComboBox Grid.Column="1" Grid.Row="2" Width="275" MaxHeight="25" ItemsSource="{Binding ContentLabels}" SelectedItem="{Binding SelectedQuestion.VarName.ContentLabel}" DisplayMemberPath="Label"/>

                    <TextBlock Text="Domain:" Grid.Column="0" Grid.Row="3" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                    <ComboBox Grid.Column="1" Grid.Row="3" MaxHeight="25" ItemsSource="{Binding DomainLabels}" SelectedItem="{Binding SelectedQuestion.VarName.DomainLabel}" DisplayMemberPath="Label"/>

                    <TextBlock Text="Product:" Grid.Column="0" Grid.Row="4" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                    <ComboBox Grid.Column="1" Grid.Row="4" MaxHeight="25" ItemsSource="{Binding ProductLabels}" SelectedItem="{Binding SelectedQuestion.VarName.ProductLabel}" DisplayMemberPath="Label"/>

                </Grid>
            </Border>
            <!-- Question Details -->
            <Border Background="LightSkyBlue" Effect="{StaticResource SunkenEffect}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition MaxHeight="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" >
                        <Button Content="PreP" Command="{Binding OpenPrePCommand}" CommandParameter="{Binding PrePID}" Width="50"/>
                        <TextBox Text="{Binding PrePID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/> 
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" >
                        <Button Content="PreI" Command="{Binding OpenPreICommand}" CommandParameter="{Binding PreIID}" Width="50"/>
                        <TextBox Text="{Binding PreIID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="2"  >
                        <Button Content="PreA" Width="50" Command="{Binding OpenPreACommand}" CommandParameter="{Binding PreAID}"/>
                        <TextBox Text="{Binding PreAID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="3" >
                        <Button Content="LitQ" Width="50" Command="{Binding OpenLitQCommand}" CommandParameter="{Binding LitQID}"/>
                        <TextBox Text="{Binding LitQID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="4" >
                        <Button Content="ROs" Width="50" Command="{Binding OpenRespOptionsCommand}" CommandParameter="{Binding RespName}"/>
                        <TextBox Text="{Binding RespName}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="5" >
                        <Button Content="NRs" Width="50" Command="{Binding OpenNRCodesCommand}" CommandParameter="{Binding NRName}"/>
                        <TextBox Text="{Binding NRName}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="6" >
                        <Button Content="PstI" Width="50" Command="{Binding OpenPstICommand}" CommandParameter="{Binding PstIID}"/>
                        <TextBox Text="{Binding PstIID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="7" >
                        <Button Content="PstP" Width="50" Command="{Binding OpenPstPCommand}" CommandParameter="{Binding PstPID}"/>
                        <TextBox Text="{Binding PstPID}" Width="70" Margin="5,0" VerticalContentAlignment="Center" IsReadOnly="{Binding Locked}"/>
                    </StackPanel>
                    
                    <!-- # comments, translations, Time Frames -->
                    <StackPanel Grid.Row="8" Margin="3">
                        <TextBlock>
                            <Run  d:Text="0" Text="{Binding SelectedQuestion.Comments.Count, Mode=OneWay}" />
                            <Run  Text=" comments."/>
                        </TextBlock>
                        <TextBlock>
                            <Run  d:Text="0" Text="{Binding SelectedQuestion.Translations.Count, Mode=OneWay}" />
                            <Run  Text=" translations."/>
                        </TextBlock>
                        <TextBlock Text="Time Frames" FontWeight="Bold" />
                        <ListBox Height="80" ItemsSource="{Binding SelectedQuestion.TimeFrames}"></ListBox>
                    </StackPanel>
                    
                    <!-- question text -->
                    <FlowDocumentScrollViewer Grid.Column="1" Grid.RowSpan="9" IsToolBarVisible="False" BorderBrush="LightGray" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" >
                        <FlowDocumentScrollViewer.Document>
                            <Binding Path="CurrentQuestionText" Converter="{StaticResource HtmlToFlow}" />
                        </FlowDocumentScrollViewer.Document>
                    </FlowDocumentScrollViewer>
                    
                </Grid>
                
            </Border>
            
        </DockPanel>
        
        <!-- Images -->
        <StackPanel Grid.Row="0" Grid.Column="2">
            <local:NavigationBar  Height="30"
                    FirstItemCommand="{Binding FirstImageCommand}"
                    PreviousItemCommand="{Binding PreviousImageCommand}"
                    ItemPosition="{Binding ImageIndex}"
                    NextItemCommand="{Binding NextImageCommand}"
                    LastItemCommand="{Binding LastImageCommand}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Width="30" Height="20" Command="{Binding AddImageCommand}">
                    <Image Source="/Images/add.png" Width="15" Height="10"></Image>
                </Button>
                <Button Width="30" Height="20" Command="{Binding DeleteImageCommand}">
                    <Image Source="/Images/delete.png" Width="15" Height="10"></Image>
                </Button>
            </StackPanel>
            
        </StackPanel>
        <DockPanel Margin="5" Grid.Column="2" Grid.Row="1" Effect="{StaticResource SunkenEffect}">
            
            <Image Source="{Binding CurrentImage.ImageSource}" Stretch="UniformToFill"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            
        </DockPanel>
        
        <!-- Comments -->
        <DockPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5" Effect="{StaticResource SunkenEffect}">
            <TextBlock DockPanel.Dock="Top" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5">
                <Run Text="Comments"/>
                <Button Command="{Binding AddCommentCommand}" Margin="10,0" VerticalAlignment="Center">
                    <Image Source="/Images/add.png" Width="15" Height="10"></Image>
                </Button>
            </TextBlock>
            <views:CommentsListView Comments="{Binding Comments}"/>
            
        </DockPanel>
    </Grid>
</UserControl>
