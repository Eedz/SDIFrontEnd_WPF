<UserControl x:Class="SDIFrontEnd_WPF.Views.HarmonyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             xmlns:viewmodels="clr-namespace:SDIFrontEnd_WPF.ViewModels"
             xmlns:behaviors="clr-namespace:MvvmLib.Behaviors;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>

      
    </UserControl.Resources>
    <Grid Background="LightGray">
        <Grid.ColumnDefinitions></Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Text="Harmony Report" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

        <TabControl Grid.Row="1">
            <TabItem Header="VarNames">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"></ColumnDefinition>
                        <ColumnDefinition Width="200"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"></RowDefinition>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <StackPanel >
                        <TextBlock Text="Vars:"/>
                        <ComboBox
                            ItemsSource="{Binding VarNameList}"
                            SelectedItem="{Binding SelectedVar}"
                            DisplayMemberPath="RefVarName"
                            IsEditable="True"
                            IsTextSearchEnabled="True"
                            StaysOpenOnEdit="True"
                            behaviors:ComboBoxBehaviors.OpenOnTyping="True"
                            TextSearch.TextPath="RefVarName"
                            ScrollViewer.CanContentScroll="True">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="4" Margin="18,0,0,0">
                        <Button Command="{Binding RemoveVarNameCommand}" CommandParameter="{Binding SelectedListVar}" Content="&lt;---" Width="75"/>
                        <Button Command="{Binding AddVarNameCommand}" CommandParameter="{Binding SelectedVar}" Content="---&gt;" Width="75" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="4">
                        <TextBlock Text="Prefixes:"/>
                        <ListBox MinHeight="200" ItemsSource="{Binding PrefixList}"
                                 behaviors:ListBoxExtensions.BindableSelectedItems="{Binding SelectedPrefixes}"></ListBox>
                    </StackPanel>

                    <DockPanel Grid.Column="4" Grid.RowSpan="3" LastChildFill="True">
                        <TextBlock Text="Selected Vars" DockPanel.Dock="Top"/>
                        <ListBox MinHeight="200" ItemsSource="{Binding SelectedVars}" SelectedItem="{Binding SelectedListVar}" DisplayMemberPath="RefVarName"/>
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Surveys">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"></ColumnDefinition>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"></ColumnDefinition>
                        <ColumnDefinition Width="100"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <StackPanel >
                        <TextBlock Text="Studies:"/>
                        <ListBox MinHeight="200" ItemsSource="{Binding StudyList}" SelectionMode="Multiple"
                                 behaviors:ListBoxExtensions.BindableSelectedItems="{Binding SelectedStudies}"/>
                    </StackPanel>
                    <DockPanel Grid.Column="1" >
                        <TextBlock Text="Waves:"/>
                        
                        <ListBox MinHeight="200" ItemsSource="{Binding WaveList}" SelectionMode="Multiple"
                                 behaviors:ListBoxExtensions.BindableSelectedItems="{Binding SelectedWaves}" />
                    </DockPanel>
                    <DockPanel Grid.Column="2">
                        <TextBlock Text="Surveys:" DockPanel.Dock="Top"/>
                        <ListBox MinHeight="200" ItemsSource="{Binding SurveyList}" SelectionMode="Multiple"
                                 SelectedItem="{Binding SelectedSurvey}"
                                 behaviors:ListBoxExtensions.BindableSelectedItems="{Binding SelectedSurveys, Mode=TwoWay}"/>
                    </DockPanel>
                    <Button Grid.Column="3" Content="&lt;5 Years Ago" Height="20" Width="100" VerticalAlignment="Top"
                            Command="{Binding SelectRecentSurveysCommand}" />
                </Grid>

            </TabItem>
            <TabItem Header="Options">
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <ListBox Width="100" MinHeight="200" ItemsSource="{Binding GroupOnList}"
                                 behaviors:ListBoxExtensions.BindableSelectedItems="{Binding SelectedGroupOnList}" SelectionMode="Multiple"/>

                    </StackPanel>
                    <StackPanel>
                        <GroupBox Header="Display">
                            <StackPanel>
                                <RadioButton Content="Surveys" 
                                        IsChecked="{Binding DisplayOption, Mode=TwoWay, 
                                            Converter={StaticResource EnumToBooleanConverter}, 
                                            ConverterParameter={x:Static viewmodels:HarmonyReportDisplay.Surveys}}"/>

                                <RadioButton Content="Projects"   
                                        IsChecked="{Binding DisplayOption, Mode=TwoWay, 
                                                               Converter={StaticResource EnumToBooleanConverter}, 
                                            ConverterParameter={x:Static viewmodels:HarmonyReportDisplay.Projects}}"/>


                            </StackPanel>

                        </GroupBox>
                        <CheckBox Content="Show Fieldwork Years" IsChecked="{Binding ShowFieldwork}"/>
                        <CheckBox Content="Show Group On Column" IsChecked="{Binding ShowGroupOn}"/>
                        <CheckBox Content="Separate Labels" IsChecked="{Binding SeparateLabels}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="File Name: "/>
            <TextBox Text="{Binding CustomFileName}" Width="200"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Open Folder" Command="{Binding OpenReportFolderCommand}"/>
            <Button Content="Single Document" Command="{Binding GenerateReportCommand}" CommandParameter="single"/>
            <Button Content="Separate Docs" Command="{Binding GenerateReportCommand}" CommandParameter="multi"/>
        </StackPanel>

    </Grid>
</UserControl>
