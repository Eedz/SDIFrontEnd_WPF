<UserControl x:Class="SDIFrontEnd_WPF.QuestionSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             xmlns:views="clr-namespace:SDIFrontEnd_WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="40"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Width="200" HorizontalAlignment="Left">
            <TextBlock Text="Survey"/>
            <ComboBox SelectedItem="{Binding SearchSurvey}"/>
            <TextBlock Text="VarName"/>
            <TextBox Text="{Binding SearchVarName}"/>
            <TextBlock Text="Search Term"/>
            <TextBox Text="{Binding SearchTerm}" Height="50" />
           
            <StackPanel Margin="0,10,0,10">
                <TextBlock Text="Look in..." FontWeight="Bold"/>
                <CheckBox Content="PreP" IsChecked="{Binding SearchPreP}"/>
                <CheckBox Content="PreI" IsChecked="{Binding SearchPreI}"/>
                <CheckBox Content="PreA" IsChecked="{Binding SearchPreA}"/>
                <CheckBox Content="LitQ" IsChecked="{Binding SearchLitQ}"/>
                <CheckBox Content="PstI" IsChecked="{Binding SearchPstI}"/>
                <CheckBox Content="PstP" IsChecked="{Binding SearchPstP}"/>
                <CheckBox Content="RO" IsChecked="{Binding SearchRO}"/>
                <CheckBox Content="NR" IsChecked="{Binding SearchNR}"/>
            </StackPanel>
            <Button Content="Search" Command="{Binding SearchCommand}" Width="150"/>
            <Button Content="Export Results" Command="{Binding ExportResults}"/>
        </StackPanel>
        
        <!--  Results -->
        <Border Grid.Column="1" Grid.Row="1" >
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" FontWeight="Bold" FontSize="14" >
                    <Run Text="{Binding FilteredResults.Count, Mode=OneWay}" />
                    <Run Text=" Questions found."/>
                </TextBlock>

                <ListBox ItemsSource="{Binding FilteredResults}"  AlternationCount="2">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#FFF5F5F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            
                            <DockPanel  >
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                    <Button Content="Export"/>
                                    <Button Content="Editor"/>
                                </StackPanel>
                                
                                <views:QuestionResultsView Height="200" />
                                
                            </DockPanel>
                            
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
