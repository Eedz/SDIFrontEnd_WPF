<UserControl x:Class="SDIFrontEnd_WPF.SurveyManager"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SDIFrontEnd_WPF"
      xmlns:dvm ="clr-namespace:SDIFrontEnd_WPF.DesignTimeViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=dvm:SurveyManagerViewModel, IsDesignTimeCreatable=True}" 
      >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition ></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="205"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
            <TextBlock   Text="Survey Manager" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Survey"/>
                <ComboBox ItemsSource="{Binding AllSurveys}" SelectedItem="{Binding CurrentSurvey}" DisplayMemberPath="SurveyCode" Margin="2,0,0,0" Width="90"/>
                <Button Command="{Binding EditSurveyInfoCommand}" Width="30" HorizontalAlignment="Right" Margin="5,0">
                    <Image Source="/Images/edit.png" Width="15" Height="15"/>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <Button Content="Import Questions" Margin="5,1" Command="{Binding ImportQuestionsCommand}"/>
                <Button Content="Import Translations" Margin="5,1" Command="{Binding ImportTranslationsCommand}"/>
                <Button Content="Checks" Visibility="Hidden"/>

            </StackPanel>
            <Border Background="White" Effect="{StaticResource SunkenEffect}" Width="700" HorizontalAlignment="Left" Margin="0,5,0,0">
                <ContentControl Content="{Binding SurveyInfo}" Margin="0,5"  />


            </Border>
        </StackPanel>

        <ContentControl BorderThickness="0" Margin="5,0" Grid.Row="1" Grid.ColumnSpan="2" Content="{Binding SurveyBuilder}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</UserControl>
