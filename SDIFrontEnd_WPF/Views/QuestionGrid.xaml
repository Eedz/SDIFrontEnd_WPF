<UserControl x:Class="SDIFrontEnd_WPF.Views.QuestionGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:viewmodels="clr-namespace:SDIFrontEnd_WPF.ViewModels"
             xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="True"
         
             KeyboardNavigation.TabNavigation="Local">
    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    </UserControl.Resources>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" >
            <TextBlock Text="Survey Question Grid" FontSize="24" HorizontalAlignment="Center"/>
            <Button Content="Headings" Command="{Binding PresetHeadingReportCommand}" Width="100"  />
            <Button Content="Overview" Command="{Binding PresetOverviewReportCommand}" Width="100"  />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" >
            <Button Content="Export" Command="{Binding ExportCommand}" Padding="4" Margin="4" Height="20" FontSize="8"/>
            <TextBlock Text="Exclude:"/>
            <CheckBox Content="Headings" IsChecked="{Binding ExcludeHeadings}" Command="{Binding UpdateScreenCommand}"/>
            <CheckBox Content="BI Scripts" IsChecked="{Binding ExcludeBI}" Command="{Binding UpdateScreenCommand}"/>
            <CheckBox Content="Non Standard Vars" IsChecked="{Binding StdOnly}" Command="{Binding UpdateScreenCommand}"/>
            <CheckBox Content="Screeners" IsChecked="{Binding ExcludeScreeners}" Command="{Binding UpdateScreenCommand}"/>

          
            <GroupBox Header="Display">
                <StackPanel Orientation="Vertical">
                    <RadioButton Content="Qnum" IsChecked="{Binding DisplayMode, Mode=TwoWay, 
                                                            Converter={StaticResource EnumToBooleanConverter}, 
                                                            ConverterParameter={x:Static viewmodels:QuestionGridDisplayMode.Qnum}}"/>

                    <RadioButton Content="Question" IsChecked="{Binding DisplayMode, Mode=TwoWay, 
                                                            Converter={StaticResource EnumToBooleanConverter}, 
                                                            ConverterParameter={x:Static viewmodels:QuestionGridDisplayMode.QuestionText}}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1">
            
        <!-- Question Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- headers -->
                <RowDefinition Height="30"/>
                <!-- scrollable content -->
                <RowDefinition/>

            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <!-- Left headers (VarNames) -->
                <ColumnDefinition/>
                <!-- Body -->
            </Grid.ColumnDefinitions>

           
            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Survey  "/>
                <ComboBox ItemsSource="{Binding AllSurveys}" DisplayMemberPath="SurveyCode" SelectedItem="{Binding SelectedSurvey}" Width="100" Margin="0,0,10,0"/>
                <Button Content="+" Command="{Binding AddSurveyCommand}" Margin="4,0" Width="25"/>
            </StackPanel>

            <!-- Top survey headers -->
            <ItemsControl Grid.Row="3" Grid.Column="2" ItemsSource="{Binding VisibleColumns}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,1,1" Width="150" Height="30" Padding="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                            <!-- Column header -->
                            <TextBlock Text="{Binding Header}"
                               FontWeight="Bold"
                               TextAlignment="Center"/>

                            <!-- Remove column button -->
                            <Button Content="✕"
                                Width="18"
                                Height="18"
                                Margin="4,0,0,0"
                                Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" />

                            <!-- Column options popup toggle -->
                                    <ToggleButton Content="⚙" Visibility="{Binding IsSurvey, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Width="18"
                                  Height="18"
                                  Margin="2,0,0,0"
                                  IsChecked="{Binding IsPopupOpen, Mode=TwoWay}"
                                  Padding="0"
                                  FontSize="10"/>

                            <!-- Popup -->
                            <Popup IsOpen="{Binding IsPopupOpen}" Placement="Bottom" StaysOpen="False">
                                <Border Padding="8" Background="White" BorderBrush="Gray" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Columns" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <!-- These checkboxes are per-survey -->
                                        <CheckBox Content="Topic" IsChecked="{Binding Options.Topic, Mode=TwoWay}"/>
                                        <CheckBox Content="Content" IsChecked="{Binding Options.Content, Mode=TwoWay}"/>
                                        <CheckBox Content="Response Options" IsChecked="{Binding Options.RespOptions, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>



            <!-- Main grid body -->
            <ItemsControl Grid.Row="4" Grid.Column="2" ItemsSource="{Binding VisibleGrid}" >
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="1,1,1,1" BorderBrush="LightGray"  Padding="4" Width="150" Height="100">
                                            <!--Width="{Binding DataContext.CellWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                Height="{Binding DataContext.CellHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">-->
                                        <StackPanel HorizontalAlignment="Center" CanVerticallyScroll="True" >
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Survey headers -->
            <DockPanel Grid.Row="2" Grid.Column="2"  HorizontalAlignment="Center">
                <ScrollBar Orientation="Horizontal"
           Minimum="0"
           Maximum="{Binding SelectedSurveys.Count}"
           SmallChange="1"
           LargeChange="10"
           ViewportSize="10"
           Value="{Binding ColumnOffset, Mode=TwoWay}"/>
            </DockPanel>

            <!-- Question grid -->
            <DockPanel  Grid.Column="0" Grid.Row="4" Grid.RowSpan="4" VerticalAlignment="Top" Height="600" >
                <ScrollBar Orientation="Vertical" 
           Minimum="0"
           Maximum="{Binding AvailableQuestions.Count}"
           SmallChange="1"
           LargeChange="20"
           ViewportSize="10"
           Value="{Binding RowOffset, Mode=TwoWay}"/>
            </DockPanel>


        </Grid>
        </Border>
    </Grid>
    

</UserControl>
