<UserControl x:Class="SDIFrontEnd_WPF.Views.WordingHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlow" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding UpdateDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}" FontWeight="Bold"/>
                <TextBlock Text="{Binding ChangeType, Mode=OneWay}" FontStyle="Italic"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock>
                    <Run Text="{Binding WordingType, Mode=OneWay}"/>
                    <Run Text=" - "/>
                    <Run Text="{Binding ID, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <FlowDocumentScrollViewer IsToolBarVisible="False" BorderBrush="LightGray" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" >
                <FlowDocumentScrollViewer.Document>
                    <Binding Path="Wording" Converter="{StaticResource HtmlToFlow}" />
                </FlowDocumentScrollViewer.Document>
            </FlowDocumentScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
