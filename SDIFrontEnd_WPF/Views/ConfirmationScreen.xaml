<UserControl x:Class="SDIFrontEnd_WPF.Views.ConfirmationScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800" Opacity="100" Height="600" Width="800" Background="#90b4d2" >
    
    <UserControl.Resources>
        <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlowDocumentConverter" />
    </UserControl.Resources>
    <Border BorderBrush="Black" BorderThickness="1">
        
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="QuestionColumn"></ColumnDefinition>
            <ColumnDefinition x:Name="CommentColumn"></ColumnDefinition>
            <ColumnDefinition x:Name="OtherColumn" Width="50"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Imported Items" Grid.ColumnSpan="3" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Grid.Column="0">
                <CheckBox Content="Save Wordings" IsChecked="{Binding CurrentApprovedQuestion.SaveWordings}"/>
                <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold">
                <Run Text="{Binding CurrentApprovedQuestion.Survey, Mode=OneWay}"/>
                <Run Text=" - " />
                <Run Text="{Binding CurrentApprovedQuestion.VarName, Mode=OneWay}"/>        
            </TextBlock>


            <FlowDocumentScrollViewer IsToolBarVisible="False" BorderBrush="LightGray"  >
                <FlowDocumentScrollViewer.Document>
                    <Binding Path="SubQuestionPreview" Converter="{StaticResource HtmlToFlowDocumentConverter}" />
                </FlowDocumentScrollViewer.Document>
            </FlowDocumentScrollViewer>


        </StackPanel>
        
        <StackPanel Grid.Row="1" Grid.Column="1">
            <CheckBox Content="Save Comments" IsChecked="{Binding CurrentApprovedQuestion.SaveComments}"/>
            <TextBlock Text="Comments" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>
            <ListBox ItemsSource="{Binding CurrentApprovedQuestion.Comments}" AllowDrop="True" MinHeight="100" ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding NoteDate}" TextWrapping="Wrap" Margin="0,0,3,0" Width="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBox}}}"/>
                            <TextBlock Text="{Binding Author}" TextWrapping="Wrap" Margin="0,0,3,0" Width="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBox}}}"/>
                            <TextBlock Text="{Binding Notes.NoteText}" TextWrapping="Wrap" Margin="0,0,3,0" Width="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBox}}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Margin ="5,5" Text="{Binding CurrentApprovedQuestion.SummaryOfChanges}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" >
            <TextBlock Margin="1" >
                <Run Text="{Binding CurrentSubRecordNumber, Mode=OneWay}"/>
                <Run Text=" of "/>
                <Run Text="{Binding TotalSubRecords, Mode=OneWay}"/>
            </TextBlock>
                <Button Command="{Binding MoveFirstSubCommand}" Margin="1" Width="25">
                    <Image Source="..\Resources\GoToFirst.png"/>
                </Button>
                <Button Command="{Binding MovePreviousSubCommand}" Width="25" Margin="1">
                    <Image Source="..\Resources\GlyphLeft.png"/>
                </Button>
                <Button Command="{Binding MoveNextSubCommand}"  Width="25" Margin="1">
                    <Image Source="..\Resources\GlyphRight.png"/>
                </Button>
                <Button  Command="{Binding MoveLastSubCommand}" Width="25" Margin="1">
                    <Image Source="..\Resources\GoToLast.png"/>
                </Button>
        </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK"  Command="{Binding SaveQuestionsCommand}" Width="50"  />
                <Button Content="Cancel"  Command="{Binding HideResultsCommand}" Width="50" Margin="10,0,0,0" />

            </StackPanel>

    </Grid>
    </Border>
</UserControl>
