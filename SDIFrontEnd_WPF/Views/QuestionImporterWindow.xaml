<Window x:Class="SDIFrontEnd_WPF.Views.QuestionImporterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SDIFrontEnd_WPF"
        xmlns:views="clr-namespace:SDIFrontEnd_WPF.Views"
        xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Question Importer" Height="1000" SizeToContent="Width" Left="0" Top="10"
        Opacity="{Binding Opacity}" Background="LightSteelBlue">
    <Window.Effect>
        <BlurEffect Radius="{Binding BlurFactor}" />
    </Window.Effect>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ViewModelDataTemplates.xaml"/>
                <ResourceDictionary>
                    <converters:QuestionTextConverter x:Key="QuestionTextConverter"/>
                    <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlowDocumentConverter" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Viewbox>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="252"></ColumnDefinition>
                <ColumnDefinition Width="1200"></ColumnDefinition>
                <ColumnDefinition x:Name="PreviewColumn" Width="400"></ColumnDefinition>

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="50"></RowDefinition>
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>

            <!-- First column, selecting Survey and Document -->
            <StackPanel Grid.Row="0" Grid.Column="0">
                <Label Content="Survey"/>
                <ComboBox ItemsSource="{Binding SurveyList}" SelectedItem="{Binding SurveyCode, Mode=TwoWay}" Margin="5,0,0,0"/>
                <Label Content="Source File"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding SourceFilePath}" Width="195" Height="50" TextWrapping="Wrap" Margin="5,0,0,0"/>
                    <Button HorizontalAlignment="Right" Content="Browse..." Command="{Binding ChooseFileCommand}" />
                </StackPanel>
                <Button Content="Import" Command="{Binding ImportDataCommand}" CommandParameter="{Binding SurveyCode.SurveyCode}" Margin="5,0,0,0" HorizontalAlignment="Left" Width="245"/>
                <TextBlock Text="{Binding ImportStatus, NotifyOnTargetUpdated=True}" TextWrapping="Wrap" Margin="5,0,0,0">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="Black" x:Name="textColorBrush"/>
                    </TextBlock.Foreground>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="textColorBrush" 
                                                Storyboard.TargetProperty="Opacity" 
                                                From="1" To="0.2" AutoReverse="True" Duration="0:0:0.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </StackPanel>
            <!-- Second column, displaying imported items -->
            <ScrollViewer Grid.Row="0" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <views:QuestionPreview />
            </ScrollViewer>
            <!-- Second column, navigation buttons -->
            <StackPanel Grid.Row="2" Grid.Column="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <TextBlock Margin="1" >
                        <Run Text="{Binding CurrentRecordNumber, Mode=OneWay}"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding TotalRecords, Mode=OneWay}"/>
                    </TextBlock>

                    <Button Command="{Binding MoveFirstCommand}" Margin="1" Width="25" >
                        <StackPanel>
                            <Image Source="Images/GoToFirst.png"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding MovePreviousCommand}" Width="25" Margin="1">
                        <Image Source="Images/GlyphLeft.png"/>
                    </Button>
                    <Button Command="{Binding MoveNextCommand}"  Width="25" Margin="1">
                        <Image Source="Images/GlyphRight.png"/>
                    </Button>
                    <Button  Command="{Binding MoveLastCommand}" Width="25" Margin="1">
                        <Image Source="Images/GoToLast.png"/>
                    </Button>
                </StackPanel>
            </StackPanel>
            <!-- Third column, Displaying question preview -->
            <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="Preview" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                <Button Command="{Binding RefreshCurrentCommand}" Width="50" HorizontalAlignment="Left" Margin="10,0,0,0">
                    <StackPanel>
                        <Image Source="Images\Refresh.png" Width="20" />
                    </StackPanel>
                </Button>
                <FlowDocumentScrollViewer IsToolBarVisible="False" BorderBrush="LightGray" VerticalScrollBarVisibility="Auto" Height="600" >
                    <FlowDocumentScrollViewer.Document>
                        <Binding Path="QuestionPreview" Converter="{StaticResource HtmlToFlowDocumentConverter}" />
                    </FlowDocumentScrollViewer.Document>
                </FlowDocumentScrollViewer>
                <Label HorizontalAlignment="Center">Approved Questions</Label>
                <ListBox HorizontalAlignment="Center" VerticalAlignment="Bottom" Width ="150" Height="225" ItemsSource="{Binding ApprovedQuestions}" SelectedItem="{Binding SelectedApprovedQuestion}">
                    <i:Interaction.Behaviors>
                        <local:ScrollIntoSelectedItemBehavior/>
                    </i:Interaction.Behaviors>
                </ListBox>
            </StackPanel>
            <!-- Third column, buttons for approving and finalizing -->
            <TextBlock Grid.Column="3" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top" Height="25" Margin="0,0,5,0">
            <Run Text="{Binding TotalSubRecords, Mode=OneWay}" />
            <Run Text=" approved."/>
            </TextBlock>
            <StackPanel Grid.Column="3" Grid.Row="1">
                <Button Content="Approve Question" Command="{Binding ApproveQuestionCommand}" Width="100" Margin="0,0,0,10"  />
                <Button Content="Import" Command="{Binding ShowResultsCommand}"  Width="100"/>
            </StackPanel>
            <!-- Popup that shows when finalizing questions -->
            <Popup IsOpen="{Binding IsPopupOpen}" Placement="Center" DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ConfirmationScreen  />
            </Popup>
        </Grid>
    </Viewbox>

</Window>
