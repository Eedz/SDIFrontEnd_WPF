<UserControl x:Class="SDIFrontEnd_WPF.Views.QuestionResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:converters ="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlow" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Width="1200">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="400"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            
        </Grid.RowDefinitions>
        <!-- question text -->
        <DockPanel Grid.Column="0" LastChildFill="True">

            <TextBlock DockPanel.Dock="Top" >
                <Run Text="{Binding SurveyCode}"/>
                <Run Text=" --- "/>
                <Run Text="{Binding VarName.VarName}"/>
                
            </TextBlock>

            
            <FlowDocumentScrollViewer DockPanel.Dock="Top" IsToolBarVisible="False" BorderBrush="Black" VerticalScrollBarVisibility="Auto" >
                <FlowDocumentScrollViewer.Document>
                    <Binding Path="QuestionTextHTML" Converter="{StaticResource HtmlToFlow}" ConverterParameter="10"/>
                </FlowDocumentScrollViewer.Document>
            </FlowDocumentScrollViewer>
            
        </DockPanel>

        <!-- Labels -->
        <Border Margin="0,0,0,0" DockPanel.Dock="Bottom" Background="LightSkyBlue" Effect="{StaticResource SunkenEffect}" Grid.Row="0" Grid.Column="1">
            <Grid Margin="5" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"></ColumnDefinition>
                    <ColumnDefinition Width="275"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Text="VarLabel:" FontWeight="Bold" Grid.Column="0" Grid.Row="0" Margin="0,0,0,10" FontSize="12" />
                <TextBox Grid.Column="1" Grid.Row="0" Width="275" MaxHeight="25" Text="{Binding VarName.VarLabel}"  Padding="3,0,0,0"/>

                <TextBlock Text="Topic:" Grid.Column="0" Grid.Row="1" Margin="0,0,0,10" FontSize="12" FontWeight="Bold" />
                <TextBox Grid.Column="1" Grid.Row="1" Width="275" MaxHeight="25" Text="{Binding VarName.Topic.LabelText}" />

                <TextBlock Text="Content:" Grid.Column="0" Grid.Row="2" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                <TextBox Grid.Column="1" Grid.Row="2" Width="275" MaxHeight="25" Text="{Binding VarName.Content.LabelText}" />

                <TextBlock Text="Domain:" Grid.Column="0" Grid.Row="3" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                <TextBox Grid.Column="1" Grid.Row="3" MaxHeight="25" Text="{Binding VarName.Domain.LabelText}" />

                <TextBlock Text="Product:" Grid.Column="0" Grid.Row="4" Margin="0,0,0,10" FontSize="12" FontWeight="Bold"/>
                <TextBox Grid.Column="1" Grid.Row="4" MaxHeight="25" Text="{Binding VarName.Product.LabelText}" />

            </Grid>
        </Border>
    </Grid>
</UserControl>
