<UserControl x:Class="SDIFrontEnd_WPF.NavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="300">
    <StackPanel HorizontalAlignment="Center" Margin="5" Orientation="Horizontal" >
        <Button Command="{Binding FirstItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Width="50" Height="15" Margin="5,0">
            <Image Source="/Images/leftdoublearrow.png"/>
        </Button>
        <Button Command="{Binding PreviousItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Width="50" Height="15" Margin="5,0">
            <Image Source="/Images/leftarrow.png"/>
        </Button>
        <TextBlock d:Text="0 of 0" 
                Text="{Binding ItemPosition, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <Button Command="{Binding NextItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Width="50" Height="15" Margin="5,0" >
            <Image Source="/Images/rightarrow.png"/>
        </Button>
        <Button Command="{Binding LastItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Width="50" Height="15" Margin="5,0">
            <Image Source="/Images/rightdoublearrow.png"/>
        </Button>
    </StackPanel>
</UserControl>
