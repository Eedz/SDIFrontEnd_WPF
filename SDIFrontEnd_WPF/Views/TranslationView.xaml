<UserControl x:Class="SDIFrontEnd_WPF.Views.TranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:converters ="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             xmlns:mvvm="clr-namespace:MvvmLib;assembly=MvvmLib"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:main="clr-namespace:SDIFrontEnd_WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Width="400" Height="600" Background="AliceBlue">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlow" />
           

            <DropShadowEffect x:Key="SunkenEffect"
              Color="Black"
              Direction="270"
              BlurRadius="5"
              ShadowDepth="1"
              Opacity="0.4"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="40"></RowDefinition>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" HorizontalAlignment="Stretch" >
            <TextBlock DockPanel.Dock="Left" d:Text="Survey Code" Text="{Binding Question.SurveyCode}" Margin="3,0"/>
            <TextBlock DockPanel.Dock="Left" d:Text="VarName" Text="{Binding Question.VarName}" Margin="3,0"/>
            <TextBlock DockPanel.Dock="Left" d:Text="Language" Text="{Binding CurrentTranslation.Language}" Margin="3,0"/>
            <Button DockPanel.Dock="Right" Content="Save" Width="35" Command="{Binding SaveCommand}"/>
        </DockPanel>

        <Border Margin="5" Grid.Row="1" Effect="{StaticResource SunkenEffect}" Background="White">
            <DockPanel HorizontalAlignment="Stretch" >
                
                <RichTextBox Margin="0" FontWeight="Bold"
                    VerticalScrollBarVisibility="Visible" IsDocumentEnabled="True"
                    mvvm:RichTextBoxHelper.Document="{Binding EnglishPreP, Mode=TwoWay}" IsReadOnly="True">

                </RichTextBox>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="2" HorizontalAlignment="Stretch" Effect="{StaticResource SunkenEffect}" Margin="5">
            
            <RichTextBox Margin="0" 
                VerticalScrollBarVisibility="Visible" AcceptsTab="True" IsDocumentEnabled="True"
                mvvm:RichTextBoxHelper.Document="{Binding CurrentTranslationText, Mode=TwoWay}" >
                <xctk:RichTextBoxFormatBarManager.FormatBar>
                    <xctk:RichTextBoxFormatBar/>
                </xctk:RichTextBoxFormatBarManager.FormatBar>
            </RichTextBox>
        </DockPanel>

        <DockPanel Margin="5" Grid.Row="3" HorizontalAlignment="Stretch" Background="White" Effect="{StaticResource SunkenEffect}">
            <RichTextBox Margin="0" FontWeight="Bold"
                VerticalScrollBarVisibility="Visible" IsDocumentEnabled="True"
                mvvm:RichTextBoxHelper.Document="{Binding EnglishPstP, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True">
                
            </RichTextBox>
        </DockPanel>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="5" Orientation="Horizontal" >
            <main:NavigationBar 
                FirstItemCommand="{Binding FirstItemCommand}"
                PreviousItemCommand="{Binding PreviousItemCommand}"
                NextItemCommand="{Binding NextItemCommand}"
                LastItemCommand="{Binding LastItemCommand}"
                ItemPosition="{Binding ItemPosition}"/>
           
        </StackPanel>
    </Grid>
</UserControl>
