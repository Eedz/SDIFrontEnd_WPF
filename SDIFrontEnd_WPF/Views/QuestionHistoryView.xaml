<UserControl x:Class="SDIFrontEnd_WPF.Views.QuestionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF.Views"
             xmlns:converters ="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlow" />
            <converters:StringToGridLengthConverter x:Key="GridLengthConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"></ColumnDefinition>
            <ColumnDefinition Width="150"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Background="#e6f8d1" Effect="{StaticResource SunkenEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!--<ColumnDefinition Width="{Binding WordingNumWidth, Converter={StaticResource GridLengthConverter}}"></ColumnDefinition>-->
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="*"></ColumnDefinition>

                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition MaxHeight="25"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" >
                    <TextBlock Text="PreP" Width="50"/>
                    <TextBox Text="{Binding SelectedVersion.PrePNum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="1" >
                    <TextBlock Text="PreI" Width="50"/>
                    <TextBox Text="{Binding SelectedVersion.PreINum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2"  >
                    <TextBlock Text="PreA" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.PreANum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3" >
                    <TextBlock Text="LitQ" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.LitQNum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" >
                    <TextBlock Text="ROs" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.RespName}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="5" >
                    <TextBlock Text="NRs" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.NRName}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="6" >
                    <TextBlock Text="PstI" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.PstINum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="7" >
                    <TextBlock Text="PstP" Width="50" />
                    <TextBox Text="{Binding SelectedVersion.PstPNum}" Width="70" Margin="5,0" VerticalContentAlignment="Center" />
                </StackPanel>
                <!-- question text -->
                <FlowDocumentScrollViewer Grid.Column="1" Grid.RowSpan="9" IsToolBarVisible="False" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" MinHeight="200" >
                    <FlowDocumentScrollViewer.Document>
                        <Binding Path="CurrentQuestionText" Converter="{StaticResource HtmlToFlow}" />
                    </FlowDocumentScrollViewer.Document>
                </FlowDocumentScrollViewer>
            </Grid>
        </Border>
        
        <StackPanel Grid.Column="1" HorizontalAlignment="Left">
            <TextBlock Text="History" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
            <ListBox ItemsSource="{Binding QuestionVersions}" SelectedItem="{Binding SelectedVersion}" Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding UpdateDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding ChangeType}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

     
    </Grid>
</UserControl>
