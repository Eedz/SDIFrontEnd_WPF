<UserControl x:Class="SDIFrontEnd_WPF.Views.PraccingImportResponseItemView"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             
             xmlns:local="clr-namespace:SDIFrontEnd_WPF" 
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
             xmlns:lib="clr-namespace:MvvmLib;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="175" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"></ColumnDefinition>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition Width="45"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
            <DatePicker SelectedDateFormat="Short" SelectedDate="{Binding Response.ResponseDate}" MaxWidth="100" 
                HorizontalAlignment="Left"/>

            <xctk:TimePicker Value="{Binding Response.ResponseDate, Mode=OneWay}" 
            Format="ShortTime" IsEnabled="False" ShowDropDownButton="False" ShowButtonSpinner="False" Width="80" Foreground="Black" >
            </xctk:TimePicker>
        </StackPanel>

        <xctk:RichTextBox Grid.Row="1" Grid.Column="0" Grid.RowSpan="4" Width="400" Height="100"  Margin="3,0,0,0" 
            VerticalScrollBarVisibility="Visible" AcceptsTab="True" IsDocumentEnabled="True" 
           
            lib:RichTextBoxHelper.Html="{Binding ResponseText}" IsReadOnly="True">
            <xctk:RichTextBoxFormatBarManager.FormatBar>
                <xctk:RichTextBoxFormatBar/>
            </xctk:RichTextBoxFormatBarManager.FormatBar>
        </xctk:RichTextBox>


        <Label Grid.Row="1" Grid.Column="1" Content="From"/>
        <!--<ComboBox Width="100"  Grid.Row="1" Grid.Column="2" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=3}}" SelectedItem="{Binding Response.ResponseFrom}"></ComboBox>-->
        <TextBox Width="100"  Grid.Row="1" Grid.Column="2" Text="{Binding Response.ResponseFrom.Name}"/>
        <Label Grid.Row="2" Grid.Column="1" Content="To"/>
        <!--<ComboBox Width="100" Grid.Row="2" Grid.Column="2"  ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=3}}" SelectedItem="{Binding Response.ResponseTo}"></ComboBox> -->
        <TextBox Width="100"   Grid.Row="2" Grid.Column="2" Text="{Binding Response.ResponseTo.Name}"/>
        <Label Grid.Row="3" Grid.Column="1" Content="PIN"/>
        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Response.PinNo}"/>
        <TextBlock Grid.Row="4" Grid.Column="2">
        <Run Text="{Binding ImageCount, Mode=OneWay}"/>
        <Run Text=" image(s)."/>
        </TextBlock>

        <ToggleButton Grid.Row="0" Grid.Column="3" Content="Keep?" IsChecked="{Binding KeepResponse}" Margin="2" Width="40" Visibility="{Binding NewResponse, Converter={StaticResource BoolToVis}}"/>
        <!--<Button Grid.Row="2" Grid.Column="3" Content="Move" Command="{Binding MoveIssueCommand, ElementName=root}" CommandParameter="{Binding Response}" Visibility="Hidden"/>-->


    </Grid>
</UserControl>
