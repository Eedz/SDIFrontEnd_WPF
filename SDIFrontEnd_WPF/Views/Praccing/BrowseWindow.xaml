<Window x:Class="SDIFrontEnd_WPF.Views.BrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SDIFrontEnd_WPF"
        xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
        mc:Ignorable="d"
        Title="Browse Issues" Height="600" Width="1200" Background="LightYellow">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" 
                      Color="Black" 
                      Opacity="0.1" 
                      BlurRadius="8" 
                      ShadowDepth="2" />
        <converters:HtmlToFlowDocumentConverter x:Key="HtmlToFlowDocumentConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Browse Issues" FontSize="24" HorizontalAlignment="Center" Grid.Row="0" Grid.ColumnSpan="4" />
        <Label Content="Survey" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="1" Grid.Column="0"/>
        <TextBlock Text="{Binding CurrentSurvey, Mode=OneTime}" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="1" Grid.Column="1"/>
        <Label Content="VarNames" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="2" Grid.Column="0"/>
        <TextBox Text="{Binding VarNameCriteria, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1"/>
        <Label Content="Recipient" Margin="10,0,0,0" Grid.Row="3" Grid.Column="0"/>
        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Recipients, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding Recipients}"/>

        <Button Command="{Binding CreateNewCommand}" Grid.Row="2" Grid.Column="2" Content="Create New"/>
        <TextBlock Text="{Binding Instructions}" TextWrapping="Wrap" Margin="10,0,0,0" Grid.Row="1" Grid.Column="3" Grid.RowSpan="3"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="4" HorizontalAlignment="Center">

            <!-- Card Display -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                  VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding PagedIssues}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="250"
                            Margin="5"
                            Padding="10"
                            Effect="{StaticResource CardShadow}">

                                <StackPanel MinHeight="250">
                                    <TextBlock Text="{Binding VarNames, Mode=OneTime}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding IssueDate.Date, Mode=OneTime}" Foreground="#666" FontStyle="Italic"/>
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="From: "/>
                                        <Run Text="{Binding IssueFrom.Name, Mode=OneTime}"/>
                                    </TextBlock>
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="To: "/>
                                        <Run Text="{Binding IssueTo.Name, Mode=OneTime}" />
                                    </TextBlock>

                                    <FlowDocumentScrollViewer IsToolBarVisible="False" BorderBrush="LightGray" Height="150" >
                                        <FlowDocumentScrollViewer.Document>
                                            <Binding Path="Description" Converter="{StaticResource HtmlToFlowDocumentConverter}" Mode="OneTime" />
                                        </FlowDocumentScrollViewer.Document>
                                    </FlowDocumentScrollViewer>

                                    <Button Content="Select" Margin="0,10,0,0" VerticalAlignment ="Bottom" HorizontalAlignment="Right"
                                        Command="{Binding DataContext.SelectIssueCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Pagination Controls -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="10">
                <Button Content="Previous"
                Command="{Binding PreviousPageCommand}"
                Margin="5"/>

                <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=" / " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center"/>

                <Button Content="Next"
                Command="{Binding NextPageCommand}"
                Margin="5"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
