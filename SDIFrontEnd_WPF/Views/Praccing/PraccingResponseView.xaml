<UserControl x:Class="SDIFrontEnd_WPF.Views.PraccingResponseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF" 
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
             xmlns:lib="clr-namespace:MvvmLib;assembly=MvvmLib"
             mc:Ignorable="d" 
             d:DesignHeight="125" d:DesignWidth="600">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"></ColumnDefinition>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition Width="30"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
            <DatePicker SelectedDateFormat="Short" SelectedDate="{Binding Response.ResponseDate}" MaxWidth="100" 
                    HorizontalAlignment="Left" local:FocusBehavior.SetSelectedItemOnFocus="True"/>

            <xctk:TimePicker Value="{Binding Response.ResponseDate, Mode=OneWay}" 
                Format="ShortTime" IsEnabled="False" ShowDropDownButton="False" ShowButtonSpinner="False" Width="60" Foreground="Black"  local:FocusBehavior.SetSelectedItemOnFocus="True">
            </xctk:TimePicker>
        </StackPanel>


        <RichTextBox Grid.Row="1" Grid.Column="0" Grid.RowSpan="4"
                Width="400" Height="100" VerticalScrollBarVisibility="Visible" AcceptsTab="True" IsDocumentEnabled="True"
                local:RichTextBoxHelper.Document="{Binding ResponseFlow, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" local:FocusBehavior.SetSelectedItemOnFocus="True">
            <xctk:RichTextBoxFormatBarManager.FormatBar>
                <xctk:RichTextBoxFormatBar/>
            </xctk:RichTextBoxFormatBarManager.FormatBar>
        </RichTextBox>

        <Label Grid.Row="1" Grid.Column="1" Content="From"/>
        <ComboBox Width="100"  Grid.Row="1" Grid.Column="2"  local:FocusBehavior.SetSelectedItemOnFocus="True" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=3}}" SelectedItem="{Binding Response.ResponseFrom}"></ComboBox>
        <Label Grid.Row="2" Grid.Column="1" Content="To"/>
        <ComboBox Width="100" Grid.Row="2" Grid.Column="2"  local:FocusBehavior.SetSelectedItemOnFocus="True" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=3}}" SelectedItem="{Binding Response.ResponseTo}"></ComboBox>
        <Label Grid.Row="3" Grid.Column="1" Content="PIN"/>
        <TextBox Grid.Row="3" Grid.Column="2"  local:FocusBehavior.SetSelectedItemOnFocus="True" Text="{Binding Response.PinNo}"/>
        <TextBlock Grid.Row="4" Grid.Column="2">
            <Run Text="{Binding ImageCount, Mode=OneWay}"/>
            <Run Text=" image(s)."/>
        </TextBlock>

        <Button Grid.Row="0" Grid.Column="3"
            Command="{Binding DataContext.DeleteResponseCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=3}}" 
            CommandParameter="{Binding Response}" Foreground="Red" VerticalAlignment="Top">X</Button>


    </Grid>
</UserControl>
