<UserControl x:Class="SDIFrontEnd_WPF.Views.PraccingIssueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
             xmlns:lib="clr-namespace:MvvmLib;assembly=MvvmLib"
             xmlns:converters="clr-namespace:MvvmLib.Converters;assembly=MvvmLib"
             xmlns:views="clr-namespace:SDIFrontEnd_WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200" Width="1200" Background="#F2E8A0">
    <UserControl.Resources>
        
        <converters:ZeroToNewConverter x:Key="ZeroToNewConverter"/>

        <converters:DirtyToImageConverter x:Key="DirtyToImageConverter"/>
    </UserControl.Resources>
    <!--<i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding OnLoadedAsyncCommand, IsAsync=True}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="500"/>
            
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="225"/>
            <RowDefinition Height="450"/>
        </Grid.RowDefinitions>
        
        <!-- Issue Entry -->
        <Border BorderBrush="Gray" BorderThickness="1" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="100"></ColumnDefinition>
                    <ColumnDefinition Width="80"></ColumnDefinition>
                    <ColumnDefinition Width="315"></ColumnDefinition>
                    <ColumnDefinition Width="110"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                </Grid.RowDefinitions>

                <Label Grid.Row="1">Issue No.</Label>
                <Label Grid.Row="2">VarNames</Label>
                <Label Grid.Row="3">Date</Label>
                <Label Grid.Row="4">From</Label>
                <Label Grid.Row="5">To</Label>
                <Label Grid.Row="6">Category</Label>

                <Button Grid.Row="0" Grid.Column="0" Command="{Binding DataContext.SaveRecordCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}"  Margin="2,0,2,0" VerticalAlignment="Center">
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Save" Margin="0,0,5,0"/>
                        <Image Width="16" Height="16"
                            Source="{Binding Dirty, Converter={StaticResource DirtyToImageConverter}, ConverterParameter='pack://application:,,,/Images/', UpdateSourceTrigger=PropertyChanged}" Opacity="1"
                               >
                            <!--<Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dirty}" Value="False">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                         Fade in instantly 
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1"
                                                         Duration="0:0:0"/>
                                                         Fade out after 2 seconds 
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0"
                                                         BeginTime="0:0:3"
                                                         Duration="0:0:1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>-->
                        </Image>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Issue.Survey.SurveyCode}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Issue.IssueNo, Converter={StaticResource ZeroToNewConverter}}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Issue.VarNames}"/>
                <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding Issue.IssueDate}"/>
                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" SelectedItem="{Binding Issue.IssueFrom}"></ComboBox>
                <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" SelectedItem="{Binding Issue.IssueTo}"></ComboBox>
                <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding DataContext.CategoryList, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" SelectedItem="{Binding Issue.Category}"></ComboBox>
                <Label Grid.Row="0" Grid.Column="2">Language</Label>
                <ListBox Grid.Row="1" Grid.Column="2" MinHeight="100" Grid.RowSpan="4" VerticalAlignment="Top" ItemsSource="{Binding DataContext.Languages, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" 
                    SelectedItem="{Binding Issue.Language}"/>
                <Label Grid.Row="5" Grid.Column="2" HorizontalAlignment="Center">PIN</Label>
                <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding Issue.PinNo}"/>
                <Label Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center">Description</Label>
                <RichTextBox Grid.Row="1" Grid.Column="3" Grid.RowSpan="6" 
                        VerticalScrollBarVisibility="Visible"
                        AcceptsTab="True"
                        IsDocumentEnabled="True"
                        local:RichTextBoxHelper.Document="{Binding DescriptionFlow, Mode=TwoWay}">          
                    <xctk:RichTextBoxFormatBarManager.FormatBar>
                        <xctk:RichTextBoxFormatBar/>
                    </xctk:RichTextBoxFormatBarManager.FormatBar>

                </RichTextBox>

                <Button Grid.Row="0" Grid.Column="4" Foreground="Red" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2,0,2,0" Width="24" Command="{Binding DataContext.DeleteIssueCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}">X</Button>
                <CheckBox Grid.Row="1" Grid.Column="4" IsChecked="{Binding Issue.Resolved}">Resolved</CheckBox>
                <DatePicker Grid.Row="2" Grid.Column="4" SelectedDate="{Binding Issue.ResolvedDate}"/>
                <ComboBox Grid.Row="3" Grid.Column="4" SelectedItem="{Binding Issue.ResolvedBy}" ItemsSource="{Binding DataContext.PeopleList, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}"/>
                <TextBlock Grid.Row="4" Grid.Column="4">
                    <Run Text="Entered By"/>
                    <Run Text="{Binding Issue.EnteredBy.Name}"/>
                </TextBlock>
                    
            </Grid>
            
        </Border>

        <!-- Issue Images -->
        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,5,0,0">
            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding DataContext.AddImageCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" Content="Add Image" Margin="0,0,5,0" Width="100"/>
                <Button Command="{Binding DataContext.DeleteImageCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}"
                        CommandParameter="{Binding ImagesVM.CurrentImage}" Content="Delete Image" Margin="0,0,5,0" Width="100"/>
            </StackPanel>
            <StackPanel >

                <ContentControl MaxHeight="230" Width="Auto" Content="{Binding ImagesVM}"/>

            </StackPanel>
        </StackPanel>

        <!-- Responses -->
        <Border BorderThickness="2" BorderBrush="Gray" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" MinWidth="700" MaxWidth="700" MaxHeight="450" HorizontalAlignment="Left" >
            <StackPanel Margin="5" >
                <StackPanel Orientation="Horizontal">
                    <Label>Responses</Label>
                    <Button Command="{Binding DataContext.AddResponseCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" Margin="10,0,0,0">Add</Button>
                </StackPanel>
                <!--<ScrollViewer VerticalScrollBarVisibility="Visible" Height="400">-->
                <DockPanel Height="400">
                    <ListBox ItemsSource="{Binding ResponsesVM}"
                        SelectedItem="{Binding DataContext.CurrentResponse, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}, UpdateSourceTrigger=PropertyChanged}"
                        VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Standard"
                             ScrollViewer.CanContentScroll="True">
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding }"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
                <!--</ScrollViewer>-->
            </StackPanel>
        </Border>

        <!-- Response Images -->
        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,5,0,0">
            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding DataContext.AddResponseImageCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" Content="Add Image" Margin="0,0,5,0" Width="100"/>
                <Button Command="{Binding DataContext.DeleteResponseImageCommand, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" CommandParameter="{Binding DataContext.ResponseImageViewModel.CurrentImage, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}" Content="Delete Image" Margin="0,0,5,0" Width="100"/>
            </StackPanel>
            <StackPanel >

                <ContentControl MaxHeight="230" Width="Auto" Content="{Binding DataContext.ResponseImageViewModel, RelativeSource={RelativeSource AncestorType=views:PraccingEntryView}}"/>

            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
