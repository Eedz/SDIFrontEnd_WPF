<UserControl x:Class="SDIFrontEnd_WPF.Views.PraccingImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SDIFrontEnd_WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="25"></RowDefinition>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" Grid.Column="0">
            <Image Source="{Binding CurrentImage.ImageSource}" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                <Image.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ShowImageCommand}"/>

                </Image.InputBindings>
            </Image>
        
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Center" >
            <StackPanel.Resources>
                <Style TargetType="Button" >
                    <Setter Property="Margin" Value="10,0,10,0"/>
                    <Setter Property="Width" Value="50"/>

                </Style>
            </StackPanel.Resources>
            <Button Command="{Binding PreviousImageCommand}" Content="&lt;"/>
            <TextBlock Margin="5">
                <Run Text="{Binding CurrentIndex, Mode=OneWay}"/>
                <Run Text=" of "/>
                <Run Text="{Binding TotalImages, Mode=OneWay}"/>
            </TextBlock>
            <Button Command="{Binding NextImageCommand}" Content="&gt;" />
        </StackPanel>

        <Popup IsOpen="{Binding ShowImagePopup}"
               Placement="Center"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Margin="20">
            <ScrollViewer Background="White" BorderBrush="Black" BorderThickness="1" >
                
                <Image Source="{Binding CurrentImage.ImageSource}" Stretch="Fill" Width="{Binding PopupWidth}" Height="{Binding PopupHeight}"/>

                
            </ScrollViewer>

        </Popup>
    </Grid>
</UserControl>
