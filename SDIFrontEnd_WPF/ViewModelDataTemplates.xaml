<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SDIFrontEnd_WPF"
                    xmlns:views="clr-namespace:SDIFrontEnd_WPF.Views"
                    xmlns:viewmodels="clr-namespace:SDIFrontEnd_WPF.ViewModels">
    <DataTemplate DataType="{x:Type local:HomeViewModel}">
        <local:HomeView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:SurveyManagerViewModel}">
        <local:SurveyManager />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:QuestionSearchViewModel}">
        <local:QuestionSearch/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:SurveyBuilderViewModel}">
        <local:SurveyBuilder />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:SurveyViewModel}">
        <local:SurveyInfoView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:SurveyEditorViewModel}">
        <local:SurveyInfoEditorView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:WordingViewModel}">
        <local:WordingEntryView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:ResponseSetViewModel}">
        <local:ResponseSetView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:TranslationViewModel}">
        <views:TranslationView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:RelatedQuestionsViewModel}">
        <views:QuestionsListView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:DeletedQuestionsViewModel}">
        <views:DeletedVarsListView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:QuickCommentEntryViewModel}">
        <views:QuickCommentEntryView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:SeriesBuilderViewModel}">
        <views:SeriesBuilder/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:TranslationImporterViewModel}">
        <views:TranslationImporterView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:HarmonyReportViewModel}">
        <views:HarmonyReportView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:QuestionSurveyMatrixViewModel}">
        <views:QuestionGrid/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:PraccingEntryViewModel}">
        <views:PraccingEntryView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewmodels:PraccingIssueViewModel}">
        <views:PraccingIssueView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewmodels:PraccingImagesViewModel}">
        <views:PraccingImagesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewmodels:PraccingResponseViewModel}">
        <views:PraccingResponseView/>
    </DataTemplate>
</ResourceDictionary>